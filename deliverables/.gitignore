# ==============================================================================
# .gitignore for the OpenHands + Headroom Docker stack
# ==============================================================================

# ---- Secrets (NEVER commit real credentials) --------------------------------
.env
.env.*
# ...but keep the template committed
!.env.example

# ---- Generated local state / runtime data -----------------------------------
workspace/
.openhands-state/
.openhands/
.headroom/

# ---- OS / editor noise -------------------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.log
*.swp
